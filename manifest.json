{
  "manifest_version": 3,
  "name": "Pantero IA — Afiliar",
  "version": "0.1.4",
  "description": "Gera link de afiliado e mensagem pronta direto da página do produto.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Pantero IA",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "clipboardWrite", "downloads"],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "*://*.amazon.com.br/*",
    "*://*.amazon.com/*",
    "*://amzn.to/*",
    "*://*.mercadolivre.com.br/*",
    "*://*.mercadolibre.com/*",
    "*://*.magazineluiza.com.br/*",
    "*://*.magazinevoce.com.br/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.com.br/*",
        "*://*.amazon.com/*",
        "*://*.mercadolivre.com.br/*",
        "*://*.magazineluiza.com.br/*",
        "*://*.magazinevoce.com.br/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
